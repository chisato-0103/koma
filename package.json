{
  "name": "koma",
  "version": "1.0.0",
  "description": "大学授業管理アプリ",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "ELECTRON_RUN_AS_NODE= electron-vite build",
    "preview": "ELECTRON_RUN_AS_NODE= electron-vite preview",
    "dist": "ELECTRON_RUN_AS_NODE= electron-vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.koma.app",
    "productName": "Koma",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/better-sqlite3/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Koma ${version}"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.1.0",
    "vite": "^5.1.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
